# =============================================================================
# FLUXAGENT V2 — CONFIGURACIÓN (.env.example)
# =============================================================================
# Este archivo sirve de plantilla para configurar el entorno de Yanua.
# Instrucciones:
#   1. Copia este archivo a un nuevo archivo llamado '.env'
#   2. Cambia los valores marcados como sensibles o 'cambiar_en_produccion'
# =============================================================================

# --- APLICACIÓN ---
APP_NOMBRE="Yanua AI"
APP_VERSION="2.1.0"
APP_ENV=development  # development | production | staging
LOG_LEVEL=INFO

# --- SEGURIDAD (CRÍTICO) ---
# Generar con: openssl rand -hex 32
JWT_SECRET=cambiar_en_produccion_muy_importante
JWT_ALGORITMO=HS256
JWT_EXPIRE_MINUTOS=60

# --- BASE DE DATOS (PostgreSQL + pgvector) ---
# Formato: postgresql://usuario:password@host:port/dbname
DATABASE_URL=postgresql://fluxadmin:fluxsecure2026@localhost:5434/fluxagent_v2
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- REDIS (Caché y Mensajería) ---
REDIS_URL=redis://:redisflux2026@localhost:6381/0

# --- OLLAMA (Local LLM Engine) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELO_CHAT=qwen2.5:3b
OLLAMA_MODELO_EMBEDDING=nomic-embed-text
OLLAMA_TIMEOUT=120
EMBEDDING_DIMENSION=768

# --- EVOLUTION API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=fluxkey123

# --- LLM CLOUD PROVIDERS (Opcional) ---
LLM_MODE=local  # local | cloud
DEFAULT_CLOUD_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- ALMACENAMIENTO ---
UPLOADS_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# --- CORS (Orígenes Permitidos) ---
# Separados por coma
CORS_ORIGINS=http://localhost:4000,http://localhost:3000,https://app.labodegaec.com

# --- TELEGRAM (Opcional) ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11