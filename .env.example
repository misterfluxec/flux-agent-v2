# =============================================================================
# FLUXAGENT V2 — VARIABLES DE ENTORNO
# =============================================================================
# Configuración para desarrollo y producción

# -------------------------------------------------------------------------
# Base de Datos
# -------------------------------------------------------------------------
DB_NAME=fluxagent_v2
DB_USER=fluxadmin
DB_PASSWORD=fluxsecure2026
DB_PORT=5434

# -------------------------------------------------------------------------
# Redis
# -------------------------------------------------------------------------
REDIS_PASSWORD=redisflux2026
REDIS_PORT=6381

# -------------------------------------------------------------------------
# Ollama Configuration
# -------------------------------------------------------------------------
OLLAMA_CONTAINER_NAME=fluxagent-ollama
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
OLLAMA_MAX_LOADED=3

# External Ollama (opcional para producción)
# OLLAMA_EXTERNAL_URL=http://external-ollama:11434

# -------------------------------------------------------------------------
# Backend Configuration
# -------------------------------------------------------------------------
BACKEND_PORT=9000

# -------------------------------------------------------------------------
# JWT Configuration
# -------------------------------------------------------------------------
JWT_SECRET=cambiar_en_produccion_jwt_secret

# -------------------------------------------------------------------------
# Application Configuration
# -------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# -------------------------------------------------------------------------
# CORS Origins
# -------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:4000,http://localhost:3000,https://app.labodegaec.com,https://api.labodegaec.com

# -------------------------------------------------------------------------
# File Upload Configuration
# -------------------------------------------------------------------------
UPLOADS_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
TIPOS_PERMITIDOS=pdf,xlsx,xls,csv,txt

# -------------------------------------------------------------------------
# Embedding Configuration
# -------------------------------------------------------------------------
EMBEDDING_DIMENSION=768

# -------------------------------------------------------------------------
# LLM Configuration
# -------------------------------------------------------------------------
LLM_MODE=local
DEFAULT_CLOUD_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=

# -------------------------------------------------------------------------
# TTS Configuration
# -------------------------------------------------------------------------
TTS_CACHE_ENABLED=true
TTS_CACHE_DIR=/app/data/media/tts_cache
TTS_CACHE_TTL=172800
TTS_CACHE_MAX_SIZE_GB=2.0
TTS_VOICE=es-MX-DaliaNeural

# -------------------------------------------------------------------------
# Evolution API (WhatsApp)
# -------------------------------------------------------------------------
EVOLUTION_API_URL=http://flux-evolution:8080
EVOLUTION_API_KEY=fluxkey123

# -------------------------------------------------------------------------
# WhatsApp Configuration
# -------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=whatsapp_verify_token

# -------------------------------------------------------------------------
# Telegram Configuration
# -------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -------------------------------------------------------------------------
# Resource Limits
# -------------------------------------------------------------------------
OLLAMA_MEMORY_LIMIT=12G
OLLAMA_CPU_LIMIT=6
